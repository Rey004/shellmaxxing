  {
    "id": "enable-firewall",
    "intent": "Enable firewall",
    "aliases": [
      "turn on firewall",
      "activate firewall",
      "enable ufw",
      "netsh firewall on"
    ],
    "windows": "netsh advfirewall set allprofiles state on",
    "linux": "sudo ufw enable",
    "mac": "sudo pfctl -E",
    "description": "Uncomplicated Firewall. Frontend for `iptables` aiming to make configuration of a firewall easier.",
    "examples": [
      "sudo ufw enable",
      "netsh advfirewall set allprofiles state on",
      "sudo ufw disable",
      "sudo ufw status numbered",
      "sudo ufw allow 5432 comment \"{{Service}}\"",
      "sudo ufw allow proto tcp from 192.168.0.4 to any port 22",
      "sudo ufw deny 80",
      "sudo ufw deny proto udp from any to any port 8412:8500",
      "sudo ufw delete {{rule_number}}"
