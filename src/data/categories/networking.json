[
  {
    "id": "show-ip-address",
    "intent": "Show ip address",
    "aliases": [
      "show my ip",
      "find ip",
      "internet address",
      "network address",
      "network address info"
    ],
    "windows": "ipconfig",
    "linux": "ip addr",
    "mac": "ifconfig",
    "description": "Show/manipulate routing, devices, policy routing and tunnels. Some subcommands such as `address` have their own usage documentation.",
    "examples": [
      "ipconfig",
      "ip addr",
      "ip {{[a|address]}}",
      "ip {{[-br|-brief]}} {{[a|address]}}",
      "ip {{[-br|-brief]}} {{[l|link]}}",
      "ip {{[r|route]}}",
      "ip {{[n|neighbour]}}",
      "sudo ip {{[l|link]}} {{[s|set]}} {{ethX}} {{up|down}}",
      "sudo ip {{[a|address]}} {{add|delete}} {{ip_address}}/{{mask}} dev {{ethX}}",
      "sudo ip {{[r|route]}} {{[a|add]}} default via {{ip_address}} dev {{ethX}}"
    ],
    "category": "networking",
    "riskLevel": "safe"
  },
  {
    "id": "ping-host",
    "intent": "Ping host",
    "aliases": [
      "test connection",
      "check network latency",
      "ping server",
      "test host connectivity"
    ],
    "windows": "ping <host>",
    "linux": "ping -c 4 <host>",
    "mac": "ping -c 4 <host>",
    "description": "Send ICMP ECHO_REQUEST packets to network hosts. See also: `mtr`.",
    "examples": [
      "ping google.com",
      "ping 10.0.0.1",
      "ping -c {{count}} {{host}}",
      "ping -i {{seconds}} {{host}}",
      "ping -n {{host}}",
      "ping -a {{host}}",
      "ping -O {{host}}",
      "ping -c {{count}} -W {{seconds}} -w {{seconds}} {{host}}",
      "ping -6 ff02::1%{{eth0}}"
    ],
    "category": "networking",
    "riskLevel": "safe"
  },
  {
    "id": "check-network-ports",
